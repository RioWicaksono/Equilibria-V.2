# ===========================================
# EQUILIBRIA - Environment Configuration
# ===========================================
# Copy this file to .env.local for local development
# DO NOT commit .env.local to git!

# ===========================================
# DATABASE (Neon PostgreSQL)
# ===========================================
# Get this from https://neon.tech -> Your Project -> Connection Details
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.pooler.aws.neon.tech/neondb?sslmode=require"

# ===========================================
# SECURITY - API Authentication
# ===========================================
# Generate with: node scripts/generate-api-key.js
# Or run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY="generate-your-own-secret-key-here"

# ===========================================
# TELEGRAM BOT (Optional)
# ===========================================
# Get from @BotFather on Telegram
# DO NOT put real token in this example file
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# ===========================================
# APP CONFIGURATION
# ===========================================
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ===========================================
# PUSH NOTIFICATIONS (Optional)
# ===========================================
# Generate VAPID keys at: https://web-push-generate-key.vercel.app/
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_EMAIL="mailto:your@email.com"

# ===========================================
# RATE LIMITING (Optional overrides)
# ===========================================
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
