# ===========================================
# EQUILIBRIA - Environment Configuration
# ===========================================
# Copy this file to .env.local for local development
# DO NOT commit .env.local to git!

# ===========================================
# DATABASE - Primary (Railway PostgreSQL)
# ===========================================
# Get this from https://railway.app -> Your Project -> PostgreSQL -> Connect
# Railway handles SSL automatically via proxy
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@hopper.proxy.rlwy.net:51135/railway"

# ===========================================
# DATABASE - Backup (Neon PostgreSQL)
# ===========================================
# Get this from https://neon.tech -> Your Project -> Connection Details
# Used as failover if Railway is unavailable
NEON_DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.pooler.aws.neon.tech/neondb?sslmode=require"

# ===========================================
# SECURITY - API Authentication
# ===========================================
# Generate with: node scripts/generate-api-key.js
# Or run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY="generate-your-own-secret-key-here"

# Cron job secret for /api/cron endpoints
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="generate-your-own-cron-secret-here"

# Allowed origins for CORS (comma-separated in production)
# Example: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS="http://localhost:3000"

# ===========================================
# TELEGRAM BOT (Optional)
# ===========================================
# Get from @BotFather on Telegram
# DO NOT put real token in this example file
TELEGRAM_BOT_TOKEN="8761494085:AAGRUwiTgYk3Glpa5I2lUOgx5IV2i76jN6c"

# ===========================================
# APP CONFIGURATION
# ===========================================
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ===========================================
# PUSH NOTIFICATIONS (Optional)
# ===========================================
# Generate VAPID keys at: https://web-push-generate-key.vercel.app/
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_EMAIL="mailto:your@email.com"

# ===========================================
# RATE LIMITING (Optional overrides)
# ===========================================
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# ERROR TRACKING - Sentry (Optional)
# ===========================================
# Get from https://sentry.io -> Your Project -> Settings -> Client Keys
# Leave empty to disable Sentry
SENTRY_DSN=""
# SENTRY_AUTH_TOKEN from https://sentry.io/settings/account/api/auth-tokens/
# Required for automatic source map uploads
# SENTRY_AUTH_TOKEN=""
