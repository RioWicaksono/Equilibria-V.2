{
  "name": "equilibria-finance",
  "version": "1.0.0",
  "description": "Aplikasi pencatatan keuangan pribadi dengan fitur lengkap",
  "private": true,
  "scripts": {
    "dev": "npx cross-env NODE_ENV=development next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "clean": "next clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:setup": "node config/scripts/setup-db.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:generate": "prisma generate",
    "key:generate": "node config/scripts/generate-api-key.js",
    "key:all": "node config/scripts/generate-api-key.js all"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.2.1",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.40.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.0.7",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.2.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.1",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-react": "^5.32.6",
    "tailwind-merge": "^3.3.1",
    "telegraf": "^4.16.3",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "19.2.16",
    "@types/react-dom": "^19",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "9.39.1",
    "eslint-config-next": "15.0.7",
    "firebase-tools": "^15.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.8.2",
    "vitest": "^2.1.9",
    "web-push": "^3.6.7"
  }
}
