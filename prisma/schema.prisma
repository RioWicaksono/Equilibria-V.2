generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Budget {
  id           String        @id @default(uuid())
  category     String        @unique
  limit        Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  budgetUsages BudgetUsage[]

  @@index([category])
}

model Transaction {
  id          String        @id @default(uuid())
  amount      Float
  type        String // 'INCOME' | 'EXPENSE'
  category    String
  date        DateTime
  description String
  createdAt   DateTime      @default(now())
  walletId    String?
  Wallet      Wallet?       @relation(fields: [walletId], references: [id])
  budgets     BudgetUsage[]

  @@index([date])
  @@index([category])
  @@index([type])
  @@index([walletId])
  @@index([date, category])
  @@index([date, type])
}

model BudgetUsage {
  id            String      @id @default(uuid())
  transactionId String
  budgetId      String
  amountUsed    Float
  createdAt     DateTime    @default(now())
  Transaction   Transaction @relation(fields: [transactionId], references: [id])
  Budget        Budget      @relation(fields: [budgetId], references: [id])

  @@index([transactionId])
  @@index([budgetId])
}

model Wallet {
  id           String        @id @default(uuid())
  name         String
  balance      Float         @default(0)
  createdAt    DateTime      @default(now())
  transactions Transaction[]

  @@index([balance])
}

model FinancialGoal {
  id            String    @id @default(uuid())
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([deadline])
}

model Debt {
  id          String    @id @default(uuid())
  name        String
  amount      Float
  paidAmount  Float     @default(0)
  type        String // 'DEBT' | 'LOAN'
  status      String // 'UNPAID' | 'PAID'
  description String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([type])
  @@index([dueDate])
}

model RecurringTransaction {
  id          String   @id @default(uuid())
  amount      Float
  type        String // 'INCOME' | 'EXPENSE'
  category    String
  description String
  frequency   String // 'DAILY' | 'WEEKLY' | 'MONTHLY' | 'YEARLY'
  nextDate    DateTime
  createdAt   DateTime @default(now())

  @@index([nextDate])
  @@index([frequency])
}

// User settings stored in database for cross-device sync
model UserSettings {
  id              String   @id @default("default")
  theme           String   @default("dark")
  language        String   @default("id")
  currency        String   @default("IDR")
  autoLockTimeout Int      @default(5)
  telegramToken   String?  @default("")
  updatedAt       DateTime @updatedAt
}

// Custom categories created by user
model CustomCategory {
  id        String   @id @default(cuid())
  name      String
  icon      String   @default("📁")
  color     String   @default("#6b7280")
  type      String   // 'INCOME' | 'EXPENSE'
  createdAt DateTime @default(now())

  @@index([type])
}

// User reminders for bills and payment schedules
model Reminder {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  amount    Float?
  status    String   @default("PENDING") // 'PENDING' | 'COMPLETED'
  priority  String   @default("MEDIUM") // 'LOW' | 'MEDIUM' | 'HIGH'
  frequency String   @default("ONCE")   // 'ONCE' | 'DAILY' | 'WEEKLY' | 'MONTHLY' | 'YEARLY'
  urgent    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([date])
  @@index([priority])
}
