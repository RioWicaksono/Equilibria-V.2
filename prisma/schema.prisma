generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  type        String   // 'INCOME' | 'EXPENSE'
  category    String
  date        DateTime
  description String
  createdAt   DateTime @default(now())
}
